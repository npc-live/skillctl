{
  "name": "@harness.farm/skillctl",
  "version": "0.1.1",
  "description": "Unified skill manager for Claude Code, Cursor, Windsurf, OpenCode, OpenClaw",
  "type": "module",
  "bin": {
    "skillctl": "dist/skillctl.mjs"
  },
  "scripts": {
    "build": "esbuild src/cli.js --bundle --platform=node --target=node18 --format=esm --external:yaml --external:fs-extra --external:execa --outfile=dist/skillctl.mjs",
    "start": "npm run build && node dist/skillctl.mjs",
    "dev": "npm run build && node dist/skillctl.mjs"
  },
  "files": [
    "dist/skillctl.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
